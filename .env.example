# Application
APP_ENV=development
APP_DEBUG=true
APP_TITLE="Netflix Clone API"
APP_VERSION="1.0.0"

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/netflix_clone

# JWT
JWT_SECRET_KEY=change-this-to-a-long-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Storage
STORAGE_BASE_DIR=./media
STORAGE_BASE_URL=http://localhost:8000/media

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
